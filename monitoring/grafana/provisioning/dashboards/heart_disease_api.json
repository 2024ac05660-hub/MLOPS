{
  "title": "Heart Disease API Dashboard",
  "uid": "hd-api-dashboard",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "title": "Total Predictions",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "sum(hd_predictions_total)",
          "legendFormat": "Total"
        }
      ],
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}}}
    },
    {
      "id": 2,
      "title": "Predictions by Class",
      "type": "piechart",
      "gridPos": {"h": 8, "w": 6, "x": 6, "y": 0},
      "targets": [
        {
          "expr": "sum by (prediction_class) (hd_predictions_total)",
          "legendFormat": "Class {{prediction_class}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Prediction Latency (p95)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 4},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(hd_prediction_latency_seconds_bucket[5m]))",
          "legendFormat": "p95 latency"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "id": 4,
      "title": "Request Rate",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "rate(http_requests_total[1m])",
          "legendFormat": "{{method}} {{handler}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Prediction Errors",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 8},
      "targets": [
        {
          "expr": "hd_prediction_errors_total",
          "legendFormat": "Errors"
        }
      ],
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"},
        "thresholds": {"steps": [{"color": "green", "value": 0}, {"color": "red", "value": 1}]}}}
    },
    {
      "id": 6,
      "title": "Confidence Score Distribution",
      "type": "histogram",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "targets": [
        {
          "expr": "hd_model_confidence_bucket",
          "legendFormat": "{{le}}"
        }
      ]
    }
  ]
}
